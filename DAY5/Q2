#include <iostream>
using namespace std;

int factorial(int n) {
    int fact = 1;
    for (int i = 1; i <= n; i++)
        fact *= i;
    return fact;
}

int main() {
    int n;
    cin >> n;

    int temp = n, sum = 0;

    while (temp) {
        sum += factorial(temp % 10);
        temp /= 10;
    }

    if (sum == n)
cout << "Strong";
    else
        cout << "Not Strong";

    return 0;
}
