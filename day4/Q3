#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int n;
    cin >> n;

    int temp = n, digits = 0;

    while (temp) {
        digits++;
        temp /= 10;
    }

    temp = n;
    int sum = 0;
while (temp) {
        sum += pow(temp % 10, digits);
        temp /= 10;
    }

    if (sum == n)
        cout << "Armstrong";
    else
        cout << "Not Armstrong";

    return 0;
}
